# --- Obrigatório: Postgres (Prisma) ---
# Opção A — Docker (na raiz do projeto: docker compose up -d):
DATABASE_URL="postgresql://flightplan:flightplan_local@localhost:5432/flightplan"
#
# Opção B — Supabase, Neon, RDS, etc. (cole a URL que o provedor te deu):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
# Para Supabase + Prisma em produção, prefira:
# DATABASE_URL="postgres://prisma.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=30"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require&connect_timeout=30"

JWT_SECRET=troque_por_um_segredo_longo_aleatorio

# Stripe (opcional — sem isso o checkout retorna modo demo)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# URLs
APP_URL=http://localhost:5173
# Em produção, use a URL pública do frontend.
# Se precisar aceitar mais de uma origem, separe por vírgula.
CORS_ORIGIN=http://localhost:5173

# Opcional — METAR/TAF via AVWX (senão usa NOAA quando der)
AVWX_TOKEN=

# Opcional — porta do backend
PORT=3001

# --- Redefinição de senha ---
# URL do frontend (link no e-mail). Deve ser a mesma origem que o usuário usa no navegador.
# APP_URL já definido acima.

# Validade do token de reset (minutos). Padrão: 60.
# PASSWORD_RESET_EXPIRY_MINUTES=60

# Validade do token de confirmação de e-mail (horas). Padrão: 48.
# EMAIL_VERIFICATION_EXPIRY_HOURS=48

# E-mail transacional (opcional — sem isso o link só aparece no console do servidor em dev)
# MAIL_FROM="Marquisa <contato@marquisa.com.br>"
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=contato@marquisa.com.br
# SMTP_PASS=

# Contatos institucionais / jurídico
# SUPPORT_EMAIL=contato@marquisa.com.br
# PRIVACY_EMAIL=contato@marquisa.com.br
# CONTACT_RECEIVER_EMAIL=contato@marquisa.com.br
#
# Dados legais exibidos em páginas/e-mails
# LEGAL_COMPANY_NAME="[preencher razão social / nome legal]"
# LEGAL_TRADE_NAME=Marquisa
# LEGAL_DOCUMENT_ID="[preencher CNPJ ou identificação aplicável]"
# LEGAL_CITY_COUNTRY="[preencher cidade/UF - Brasil]"
# SUPPORT_HOURS="Segunda a sexta, em horário comercial."
# LEGAL_REFUND_SUMMARY="Defina aqui a política comercial final."
#
# Versionamento documental
# LEGAL_TERMS_VERSION=2026-05-12
# LEGAL_PRIVACY_VERSION=2026-05-12
# LEGAL_CANCELLATION_VERSION=2026-05-12

# Produção
# NODE_ENV=production
