generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  emailVerifiedAt        DateTime?
  emailVerificationToken String?   @unique
  emailVerificationExpires DateTime?
  plan       String   @default("FREE")
  planStatus String? // active | trialing | past_due | canceled | demo
  preferredLocale String @default("pt-BR")
  currentPeriodEnd DateTime?
  trialEndsAt      DateTime?
  cancelAtPeriodEnd Boolean @default(false)
  canceledAt       DateTime?

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  createdAt DateTime @default(now())

  briefings Briefing[]
  favorites Favorite[]
  consents  Consent[]
  contactMessages ContactMessage[]
  emailLogs EmailLog[]
  aircraftProfiles AircraftProfile[]
  examAttempts ExamAttempt[]
}

model Briefing {
  id        String   @id @default(uuid())
  userId    String
  data      Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  icao      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, icao])
}

model Consent {
  id             String   @id @default(uuid())
  userId         String
  termsVersion   String
  privacyVersion String
  ipAddress      String?
  userAgent      String?
  acceptedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(uuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("received")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  emailLogs EmailLog[]
}

model EmailLog {
  id               String   @id @default(uuid())
  userId           String?
  contactMessageId String?
  kind             String
  toEmail          String
  subject          String
  status           String
  provider         String?
  providerEventId  String?
  error            String?
  metadata         Json?
  createdAt        DateTime @default(now())
  sentAt           DateTime?

  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  contactMessage ContactMessage? @relation(fields: [contactMessageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contactMessageId])
  @@index([kind, status])
  @@index([kind, providerEventId])
}

model AircraftProfile {
  id           String   @id @default(uuid())
  userId       String
  name         String
  registration String?
  presetKey    String?
  family       String?
  isDefault    Boolean  @default(false)
  notes        String?
  data         Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model ExamAttempt {
  id              String    @id @default(uuid())
  userId          String
  license         String
  mode            String
  subject         String?
  questionIds     Json
  answers         Json?
  score           Json?
  totalQuestions  Int       @default(0)
  correctAnswers  Int       @default(0)
  percent         Float     @default(0)
  passed          Boolean   @default(false)
  status          String    @default("in_progress")
  durationSeconds Int       @default(0)
  startedAt       DateTime  @default(now())
  submittedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([license, mode])
}
